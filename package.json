{
  "name": "coot-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3000",
    "dev:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3000",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:3001": "next dev -p 3001",
    "dev:3001:clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\" && next dev -p 3001",
    "dev:open": "concurrently \"next dev -p 3000\" \"node scripts/wait-and-open.mjs --port=3000 --path=/\"",
    "dev:open:3001": "concurrently \"next dev -p 3001\" \"node scripts/wait-and-open.mjs --port=3001 --path=/\"",
    "build": "next build",
    "start": "next start -p 3000",
    "preview": "next build && next start -p 3000",
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true})\"",
    "dev:open:clean": "npm run clean && concurrently \"next dev -p 3000\" \"node scripts/wait-and-open.mjs --port=3000 --path=/\"",
    "lint": "eslint",
    "mascot:knockout": "node scripts/knockout-mascot.mjs"
  },
  "dependencies": {
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
