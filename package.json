{
  "name": "coot-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/dev-auto.mjs",
    "dev:no-open": "next dev -p 3000",
    "clean:cache": "node scripts/clean-cache.mjs",
    "dev:clean": "node scripts/clean-cache.mjs && node scripts/dev-auto.mjs",
    "dev:lan": "next dev -H 0.0.0.0 -p 3000",
    "dev:3001": "concurrently \"next dev -p 3001\" \"node scripts/wait-and-open.mjs --port=3001 --path=/ --immediate\"",
    "dev:3001:no-open": "next dev -p 3001",
    "dev:3001:clean": "node scripts/clean-cache.mjs && npm run dev:3001",
    "dev:open": "npm run dev",
    "dev:open:3001": "npm run dev:3001",
    "build": "next build",
    "start": "next start -p 3000",
    "preview": "next build && next start -p 3000",
    "clean": "node scripts/clean-cache.mjs",
    "dev:open:clean": "node scripts/clean-cache.mjs && node scripts/dev-auto.mjs",
    "lint": "eslint",
    "mascot:knockout": "node scripts/knockout-mascot.mjs"
  },
  "dependencies": {
    "@supabase/ssr": "^0.9.0",
    "@supabase/supabase-js": "^2.100.1",
    "next": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "eslint": "^9",
    "eslint-config-next": "^15.1.0",
    "postcss": "^8.4.49",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^5"
  }
}
