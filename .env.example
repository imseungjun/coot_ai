# 선택: OG·메타데이터용 절대 URL
# 로컬: http://localhost:3000
# Vercel 배포 후: https://프로젝트이름.vercel.app
# NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# 회원가입·클라우드 동기화 (Supabase 프로젝트 → Settings → API)
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# 로컬에서 next start 로 띄울 때만: 화면의「프로젝트 폴더에 저장」으로 data/hub-baseline.json 쓰기 허용
# (npm run dev 는 기본 허용. 공개 서버에는 설정하지 마세요.)
# HUB_BASELINE_WRITE=1
