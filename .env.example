# --- Vercel 배포 시: Settings → Environment Variables 에 아래 3개를 동일하게 넣고 Redeploy ---
# 로그인·회원가입(Supabase) 필수: URL, anon 키
# NEXT_PUBLIC_SUPABASE_URL="https://xxxx.supabase.co"
# NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# OG·메타데이터·백업용. 로컬: http://localhost:3000 / 배포: https://프로젝트이름.vercel.app (끝 슬래시 없음)
# NEXT_PUBLIC_SITE_URL="https://your-project.vercel.app"

# 자세한 순서: docs/Vercel-로그인-Supabase.md

# 로컬에서 next start 로 띄울 때만: 화면의「프로젝트 폴더에 저장」으로 data/hub-baseline.json 쓰기 허용
# (npm run dev 는 기본 허용. 공개 서버에는 설정하지 마세요.)
# HUB_BASELINE_WRITE=1
